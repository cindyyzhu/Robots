#include <Servo.h>

Servo myServo;

const int potPin = A0;    // potentiometer middle pin
const int servoPin = 9;   // servo signal wire

void setup() {
  myServo.attach(servoPin);
}

void loop() {
  int potValue = analogRead(potPin);           // reads 0–1023
  int angle = map(potValue, 0, 1023, 0, 180);  // convert to 0–180 degrees
  myServo.write(angle);
  delay(15);  // give the servo time to move
}
